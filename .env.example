# Medikah Chat Frontend - Environment Variables
# Copy this file to .env.local and fill in values

# ===========================================
# CORE CONFIGURATION (required)
# ===========================================

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=  # Generate with: openssl rand -base64 32

# ===========================================
# DATABASE (optional - Supabase)
# ===========================================

# Supabase (enables persistent auth; falls back to demo credentials if not set)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ===========================================
# ANALYTICS & MONITORING (production)
# ===========================================

# Google Analytics 4 Measurement ID
# Get from: Google Analytics > Admin > Data Streams > Web
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Sentry Error Tracking DSN
# Get from: Sentry > Project Settings > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=

# ===========================================
# EMAIL SERVICE (production)
# ===========================================

# Resend API Key (for transactional emails)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# From email address (must be verified in Resend)
EMAIL_FROM=noreply@medikah.health

# Base URL for email links (used in transactional emails)
NEXT_PUBLIC_BASE_URL=https://medikah.health

# ===========================================
# LINKEDIN OAUTH (physician profile import)
# ===========================================

# LinkedIn App Credentials
# Get from: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# OAuth callback URL (must match LinkedIn app settings)
LINKEDIN_REDIRECT_URI=https://medikah.health/api/auth/linkedin/callback

# ===========================================
# DEVELOPMENT ONLY
# ===========================================

# Demo credentials (fallback when Supabase is not configured)
DEMO_EMAIL=
DEMO_PASSWORD=

# =======================================================================
# Phase 10 — Práctikah infrastructure (Vendor + Infrastructure Bring-up)
# Do NOT commit real values. Populate in Netlify dashboard per D-14.
# Canonical source: .planning/phases/10-vendor-infrastructure-bring-up/runbooks/secrets-manifest.md
# =======================================================================

# --- Vultr (VPS + Object Storage) ---
VULTR_API_TOKEN=
VULTR_OBJECT_STORAGE_S3_HOSTNAME=
VULTR_OBJECT_STORAGE_S3_BUCKET=medikah-mailcow-backup-prod
VULTR_OBJECT_STORAGE_S3_KEY=
VULTR_OBJECT_STORAGE_S3_SECRET=

# --- AWS (SES outbound relay, us-east-2) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_SMTP_USERNAME=
AWS_SES_SMTP_PASSWORD=

# --- Cloudflare (DNS + Registrar + CF for SaaS) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID_MEDIKAH_HEALTH=

# --- OpenSRS (ccTLD fallback registrar — Phase 13 consumer, staged in Phase 10) ---
OPENSRS_RESELLER_USERNAME=
OPENSRS_RESELLER_API_KEY=

# --- Mailcow (self-hosted mail server at practikah.medikah.health) ---
MAILCOW_API_KEY=
MAILCOW_ADMIN_URL=https://practikah.medikah.health/admin
MAILCOW_ADMIN_PASSWORD=
MAILCOW_LUKS_PASSPHRASE=
MAILCOW_TEST_MAILBOX_PASSWORD=

# =======================================================================
# Phase 12 — Práctikah workspace (frontend additions)
# =======================================================================

# --- Internal FastAPI → Next.js email trigger (Phase 12-02) ---
# 32+ char random string; rotate quarterly.
# MUST match the INTERNAL_API_SHARED_SECRET value set in the Render (FastAPI) dashboard.
# Generate with: openssl rand -base64 32
INTERNAL_API_SHARED_SECRET=

# Next.js internal base URL (used by FastAPI notifications.py to call back into Next.js)
# In production this is the same as NEXT_PUBLIC_BASE_URL.
# In local dev, FastAPI on :8000 → Next.js on :3000.
NEXT_INTERNAL_URL=https://medikah.health

# Práctikah transactional email From address
PRACTIKAH_EMAIL_FROM=practikah@medikah.health

# Supabase service role key (server-side only — used by practikah BFF API routes)
SUPABASE_SERVICE_ROLE_KEY=
